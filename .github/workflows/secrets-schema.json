{
  "$schema": "https://json.schemastore.org/github-workflow.json",
  "secrets": {
    "DOCKER_USERNAME": {
      "description": "Docker Hub username for pushing container images",
      "required": true
    },
    "DOCKER_PASSWORD": {
      "description": "Docker Hub access token (not password)",
      "required": true
    },
    "SNYK_TOKEN": {
      "description": "Snyk security scanning token",
      "required": false
    }
  }
}
