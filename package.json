{
  "name": "biblefunland-vite-mxde",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "dev:all": "concurrently -n \"client,server\" -c \"cyan,yellow\" \"npm run dev\" \"npm run server\"",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "vite build && open dist/stats.html",
    "lint": "eslint src --ext .jsx,.js",
    "lint:fix": "eslint src --ext .jsx,.js --fix",
    "format": "prettier --write \"src/**/*.{jsx,js,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{jsx,js,css,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@clerk/clerk-react": "^5.61.4",
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@clerk/express": "^2.0.7",
    "@clerk/ui": "^1.3.0",
    "@emailjs/browser": "^4.4.1",
    "@libsql/client": "^0.17.2",
    "@stripe/stripe-js": "^8.11.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "morgan": "^1.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.0",
    "resend": "^6.9.4",
    "stripe": "^21.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.1",
    "@babel/eslint-parser": "^7.25.9",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "concurrently": "^9.2.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "rollup-plugin-visualizer": "^5.12.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "src/**/*.{jsx,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
