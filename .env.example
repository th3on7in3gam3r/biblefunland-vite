# ============================================================
# BibleFunLand — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore already.
# ============================================================

# ── Clerk (Auth) — get from clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key-here

# ── Turso (Database) — get from turso.tech
VITE_TURSO_DATABASE_URL=libsql://your-db-name.aws-us-east-1.turso.io
VITE_TURSO_AUTH_TOKEN=your-turso-token-here

# ── Anthropic AI (get from https://console.anthropic.com)
VITE_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Admin PIN (4-digit number, change this immediately!)
VITE_ADMIN_PIN=1234

# ── Stripe (get from https://dashboard.stripe.com → Developers → API keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key-here

# ── App Config
VITE_APP_NAME=BibleFunLand
VITE_APP_URL=https://biblefunland.com

# ── Google AdSense (get from adsense.google.com → Account → Publisher ID)
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXX

# ── Google Analytics 4 (get from analytics.google.com → Data Streams → Measurement ID)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site Info (used in Privacy Policy and SEO)
VITE_SITE_URL=https://biblefunland.com
VITE_CONTACT_EMAIL=hello@biblefunland.com

# ── Resend (Email) — get from resend.com
VITE_RESEND_API_KEY=re_your-resend-key-here
